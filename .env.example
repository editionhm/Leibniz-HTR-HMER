# ====================================================================
# Configuration for the Leibniz Manuscript HTR/HMER Webapp
# ====================================================================

# Port for the FastAPI backend (and the frontend when served in production)
BACKEND_PORT=8000

# Activates mock mode when GPU or fine-tuned model checkpoint is not loaded.
# Set to 'false' in production or when running with GPU.
MOCK_MODE=true

# Model Configuration
# Can be a HuggingFace hub path (e.g. "phxember/Uni-MuMER-Qwen3.5-2B") or a local absolute directory.
MODEL_NAME_OR_PATH=phxember/Uni-MuMER-Qwen3.5-2B


# LoRA Adapter path.
# Set to the path of your extracted Unsloth adapter files (e.g. j:/downloads/best_clean_htr_plain_exprate)
# Leave blank if using a fully merged model.
LORA_ADAPTER_PATH=

# Dtype and target device settings (cuda or cpu)
DEVICE=cuda
LOAD_IN_4BIT=true
MAX_NEW_TOKENS=512
TEMPERATURE=0.0
